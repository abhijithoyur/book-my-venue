# Copy this file to .env and update values for your environment

# Database Configuration
DATABASE_NAME=bookmyvenue
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
DATABASE_HOST=db
DATABASE_PORT=5432

# Django Settings
DEBUG=True
SECRET_KEY=dev-secret-key-change-in-production-with-random-string
ALLOWED_HOSTS=localhost,127.0.0.1,api

# CORS Configuration (for frontend)
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# JWT Configuration
JWT_ACCESS_TOKEN_LIFETIME=900  # 15 minutes in seconds
JWT_REFRESH_TOKEN_LIFETIME=604800  # 7 days in seconds
JWT_ALGORITHM=HS256

# Email Configuration
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=noreply@bookmyvenue.com

# Frontend Configuration
VITE_API_BASE_URL=http://localhost:8000/api/v1

# AWS S3 (for image uploads - future)
AWS_STORAGE_BUCKET_NAME=book-my-venue
AWS_S3_REGION_NAME=ap-south-1
AWS_S3_CUSTOM_DOMAIN=d1234567890.cloudfront.net

# Celery Configuration (for async tasks - future)
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# Redis Configuration (for caching - future)
REDIS_URL=redis://redis:6379/0

# Logging
LOG_LEVEL=INFO

# Feature Flags
ENABLE_EMAIL_VERIFICATION=True
ENABLE_ANALYTICS=False
ENABLE_PAYMENTS=False

# Timezone
TIME_ZONE=Asia/Kolkata

# App Environment
ENVIRONMENT=development
